// Test-only config. Production deployment is managed via Terraform.
{
  "name": "open-inspect-control-plane-test",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      { "name": "SESSION", "class_name": "SessionDO" },
      { "name": "SCHEDULER", "class_name": "SchedulerDO" },
      { "name": "BOARD_ROOM", "class_name": "BoardRoom" },
    ],
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["SessionDO"] },
    { "tag": "v2", "new_sqlite_classes": ["SchedulerDO"] },
    { "tag": "v3", "new_sqlite_classes": ["BoardRoom"] },
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "database_name": "open-inspect-test",
    },
  ],
  "kv_namespaces": [{ "binding": "REPOS_CACHE", "id": "00000000000000000000000000000000" }],
  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "open-inspect-media-test",
    },
  ],
}
